{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nkkmd/bao-la-kiswahili-game/schemas/phase-transition-observation.schema.json",
  "title": "Bao phase-transition ply observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "ply", "player", "phase", "stateHash", "reserve", "houseOwned", "legalMoveCount", "captureMoveCount", "nonCaptureMoveCount", "forcedCapture", "frontRow"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "gameId": {"type": "string", "minLength": 1},
    "conditionId": {"type": "string", "minLength": 1},
    "seed": {"type": ["integer", "string"]},
    "ply": {"type": "integer", "minimum": 0},
    "player": {"type": "integer", "enum": [0, 1]},
    "phase": {"type": "string", "enum": ["namua", "mtaji"]},
    "winner": {"type": ["integer", "null"], "enum": [0, 1, null]},
    "reason": {"type": "string"},
    "stateHash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "previousStateHash": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "reserve": {"type": "array", "prefixItems": [{"type": "integer", "minimum": 0}, {"type": "integer", "minimum": 0}], "minItems": 2, "maxItems": 2},
    "houseOwned": {"type": "array", "prefixItems": [{"type": "boolean"}, {"type": "boolean"}], "minItems": 2, "maxItems": 2},
    "pending": {"type": "array", "prefixItems": [{"type": "integer", "minimum": 0}, {"type": "integer", "minimum": 0}], "minItems": 2, "maxItems": 2},
    "legalMoveCount": {"type": "integer", "minimum": 0},
    "captureMoveCount": {"type": "integer", "minimum": 0},
    "nonCaptureMoveCount": {"type": "integer", "minimum": 0},
    "forcedCapture": {"type": "boolean"},
    "boardSeedCount": {"type": "integer", "minimum": 0},
    "nonEmptyPitCount": {"type": "integer", "minimum": 0, "maximum": 32},
    "frontRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["occupiedPits", "occupancyRate", "seedCount"],
      "properties": {
        "occupiedPits": {"type": "array", "prefixItems": [{"type": "integer", "minimum": 0, "maximum": 8}, {"type": "integer", "minimum": 0, "maximum": 8}], "minItems": 2, "maxItems": 2},
        "occupancyRate": {"type": "array", "prefixItems": [{"type": "number", "minimum": 0, "maximum": 1}, {"type": "number", "minimum": 0, "maximum": 1}], "minItems": 2, "maxItems": 2},
        "seedCount": {"type": "array", "prefixItems": [{"type": "integer", "minimum": 0}, {"type": "integer", "minimum": 0}], "minItems": 2, "maxItems": 2}
      }
    }
  }
}
